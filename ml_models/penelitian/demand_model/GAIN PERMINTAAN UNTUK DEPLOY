import random\n","from google.colab import drive\n","\n","# ==========================================\n","# RANDOM SEED (stabil)\n","# ==========================================\n","SEED = 42\n","os.environ[\"PYTHONHASHSEED\"] = str(SEED)\n","np.random.seed(SEED)\n","tf.random.set_seed(SEED)\n","random.seed(SEED)\n","\n","\n","class GainImputerDemandProvinsi:\n","    def __init__(self, model_dir: str):\n","        # Load scaler dan statistik kolom\n","        self.scaler = joblib.load(os.path.join(model_dir, \"scaler_gain.pkl\"))\n","        self.col_means = np.load(os.path.join(model_dir, \"col_means.npy\"))\n","\n","        # Load urutan nama fitur\n","        with open(os.path.join(model_dir, \"feature_names.json\"), \"r\") as f:\n","            self.feature_names = json.load(f)\n","\n","        # Load generator GAIN (format .h5, sama dengan saat training)\n","        self.generator = tf.keras.models.load_model(\n","            os.path.join(model_dir, \"gain_generator.h5\"),\n","            compile=False,\n","        )\n","\n","    def _build_row(self, input_dict: dict) -> pd.DataFrame:\n","        # Susun satu baris data sesuai urutan feature_names\n","        data = {col: [input_dict.get(col, np.nan)] for col in self.feature_names}\n","        return pd.DataFrame(data)\n","\n","    def impute(self, input_dict: dict) -> pd.DataFrame:\n","        # Bangun DataFrame 1 baris\n","        df = self._build_row(input_dict)\n","        X = df.values.astype(float)\n","\n","        # Mask missing (1 = ada data, 0 = missing)\n","        M = 1 - np.isnan(X).astype(float)\n","\n","        # Isi sementara dengan mean kolom dari training\n","        X_filled = X.copy()\n","        for j in range(X_filled.shape[1]):\n","            X_filled[:, j] = np.where(\n","                np.isnan(X_filled[:, j]),\n","                self.col_means[j],\n","                X_filled[:, j],\n","            )\n","\n","        # Normalisasi pakai scaler training\n","        X_norm = self.scaler.transform(X_filled)\n","\n","        # Di posisi yang aslinya NaN, isi 0 di ruang ternormalisasi\n","        X_norm = np.where(np.isnan(X), 0.0, X_norm)\n","\n","        no, dim = X_norm.shape\n","\n","        # Noise Z_full (0–0.01, sama dengan bagian imputasi full di training)\n","        Z_full = np.random.uniform(0, 0.01, size=(no, dim)).astype(np.float32)\n","\n","        # Input ke generator: X_in_full + mask\n","        X_in_full = (X_norm * M) + (1 - M) * Z_full\n","        G_in_full = np.concatenate(\n","            [X_in_full.astype(np.float32), M.astype(np.float32)],\n","            axis=1,\n","        )\n","\n","        # Prediksi imputasi ternormalisasi\n","        imputed_norm = self.generator.predict(G_in_full, verbose=0)\n","        imputed_norm = (M * X_norm) + ((1 - M) * imputed_norm)\n","\n","        # Balik ke skala asli\n","        imputed = self.scaler.inverse_transform(imputed_norm)\n","\n","        return pd.DataFrame(imputed, columns=self.feature_names)\n","\n","\n","if __name__ == \"__main__\":\n","    # Mount Google Drive\n","    drive.mount(\"/content/drive\")\n","\n","    # Folder model hasil training\n","    base_dir = (\n","        \"/content/drive/MyDrive/\"\n","        \"HASIL DATASET PERMINTAAN 26 KANWIL BULOG (BAPANAS)/\"\n","        \"Hasil Imputasi/models_gain_permintaan\"\n","    )\n","\n","    provinsi = \"Jawa Barat\"  # contoh, sesuaikan dengan nama folder provinsi\n","    model_dir = os.path.join(base_dir, provinsi)\n","\n","    imputer = GainImputerDemandProvinsi(model_dir)\n","\n","    # Contoh input (sesuaikan dengan feature_names.json)\n","    contoh_input = {\n","        \"Konsumsi_Rasio\": None,\n","        \"Penduduk\": 5_000_000,\n","        \"Harga_Beras\": 12_000,\n","        # kolom lain bisa ditambahkan, yang tidak diisi akan dianggap NaN\n","    }\n","\n","    hasil = imputer.impute(contoh_input)\n","    print(hasil)"],"metadata":{"id":"5WPMDHrXnJoc"},"execution_count":null,"outputs":[]}],"metadata":{"colab":