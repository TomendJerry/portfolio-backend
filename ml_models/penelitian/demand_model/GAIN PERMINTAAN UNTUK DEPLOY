Seed\n","SEED = 42\n","np.random.seed(SEED)\n","tf.random.set_seed(SEED)\n","\n","# Drive & path\n","drive.mount('/content/drive')\n","FILE_PATH = \"/content/drive/MyDrive/HASIL DATASET PERMINTAAN 26 KANWIL BULOG (BAPANAS)/DATASET PERMINTAAN 26 KANWIL.xlsx\"\n","OUTPUT_DIR = \"/content/drive/MyDrive/HASIL DATASET PERMINTAAN 26 KANWIL BULOG (BAPANAS)/Hasil Imputasi\"\n","os.makedirs(OUTPUT_DIR, exist_ok=True)\n","OUT_XLSX = os.path.join(OUTPUT_DIR, \"Imputasi GAIN 3.1.xlsx\")\n","OUT_WAKTU = os.path.join(OUTPUT_DIR, \"LAPORAN_WAKTU_IMPUTASI_GAIN 3.1.xlsx\")\n","\n","# ====== Fungsi utama GAIN ======\n","def gain_imputation(data_x, gain_parameters):\n","    no, dim = data_x.shape\n","    if dim == 0: return data_x\n","    M = 1 - np.isnan(data_x).astype(float)\n","\n","    # Pra-isi mean kolom (setelah prefill global di luar fungsi)\n","    X_filled = data_x.copy()\n","    col_means = np.nanmean(X_filled, axis=0)\n","    col_means = np.where(np.isnan(col_means), 0.0, col_means)  # fallback jika masih NaN\n","    for j in range(dim):\n","        X_filled[:, j] = np.where(np.isnan(X_filled[:, j]), col_means[j], X_filled[:, j])\n","\n","    scaler = MinMaxScaler((0, 1))\n","    norm_data_x = scaler.fit_transform(X_filled)\n","    norm_data_x = np.where(np.isnan(data_x), 0.0, norm_data_x)\n","\n","    batch = gain_parameters.get('batch_size', 128)\n","    hint = gain_parameters.get('hint_rate', 0.7)\n","    alpha = gain_parameters.get('alpha', 500)\n","    iters = gain_parameters.get('iterations', 15000)\n","    patience = gain_parameters.get('patience', 500)\n","\n","    tf.keras.backend.clear_session()\n","    G = tf.keras.Sequential([\n","        tf.keras.layers.InputLayer((dim*2,)),\n","        tf.keras.layers.Dense(dim*2, activation='relu'),\n","        tf.keras.layers.Dense(dim*2, activation='relu'),\n","        tf.keras.layers.Dense(dim,   activation='relu'),\n","        tf.keras.layers.Dense(dim,   activation='relu'),\n","        tf.keras.layers.Dense(dim, activation='sigmoid')\n","    ])\n","    D = tf.keras.Sequential([\n","        tf.keras.layers.InputLayer((dim*2,)),\n","        tf.keras.layers.Dense(dim, activation='relu'),\n","        tf.keras.layers.Dense(dim, activation='relu'),\n","        tf.keras.layers.Dense(dim, activation='sigmoid')\n","    ])\n","\n","    loss = tf.keras.losses.BinaryCrossentropy()\n","    def g_loss(d_prob, m, g_samp, x):\n","        adv = -tf.reduce_mean((1 - m) * tf.math.log(d_prob + 1e-8))\n","        rec = tf.reduce_mean(tf.square((m * x) - (m * g_samp)))\n","        return adv + alpha * rec\n","\n","    g_opt = tf.keras.optimizers.Adam()\n","    d_opt = tf.keras.optimizers.Adam()\n","    best, wait = float('inf'), 0\n","    for _ in range(iters):\n","        idx = np.random.permutation(no)[:batch]\n","        X_mb, M_mb = norm_data_x[idx, :], M[idx, :].astype(np.float32)\n","        Z_mb = np.random.uniform(0, 0.1, [len(idx), dim]).astype(np.float32)\n","        B_mb = np.random.binomial(1, hint, M_mb.shape).astype(np.float32)\n","        H_mb = M_mb * B_mb + 0.5 * (1 - B_mb)\n","        X_in = (X_mb * M_mb) + (1 - M_mb) * Z_mb\n","        G_in = tf.concat([tf.cast(X_in, tf.float32), M_mb], axis=1)\n","        with tf.GradientTape() as g_t, tf.GradientTape() as d_t:\n","            G_samp = G(G_in)\n","            X_hat = (tf.cast(X_mb, tf.float32) * M_mb) + (G_samp * (1 - M_mb))\n","            D_in = tf.concat([X_hat, tf.cast(H_mb, tf.float32)], axis=1)\n","            D_pr = D(D_in)\n","            d_l = loss(M_mb, D_pr)\n","            g_l = g_loss(D_pr, M_mb, G_samp, tf.cast(X_mb, tf.float32))\n","        d_opt.apply_gradients(zip(d_t.gradient(d_l, D.trainable_variables), D.trainable_variables))\n","        g_opt.apply_gradients(zip(g_t.gradient(g_l, G.trainable_variables), G.trainable_variables))\n","        if g_l < best:\n","            best, wait = g_l, 0\n","        else:\n","            wait += 1\n","        if wait >= patience:\n","            break\n","\n","    Z_full = np.random.uniform(0, 0.01, norm_data_x.shape).astype(np.float32)\n","    X_in_full = (norm_data_x * M) + (1 - M) * Z_full\n","    G_in_full = tf.concat([tf.cast(X_in_full, tf.float32), tf.cast(M, tf.float32)], axis=1)\n","    imputed_norm = G(G_in_full).numpy()\n","    imputed_norm = (M * norm_data_x) + ((1 - M) * imputed_norm)\n","    imputed = scaler.inverse_transform(imputed_norm)\n","    return (M * np.where(np.isnan(data_x), 0.0, data_x)) + ((1 - M) * imputed)\n","\n","# ====== Imputasi Final ======\n","start = time.time()\n","df = pd.read_excel(FILE_PATH)\n","\n","# Rapikan label provinsi\n","df['Provinsi'] = df['Provinsi'].astype(str).str.strip()\n","\n","# Semua kolom numerik kecuali Tahun\n","num_cols = df.select_dtypes(include=np.number).columns.drop('Tahun', errors='ignore').tolist()\n","\n","# Mask awal untuk styling\n","mask_missing = df[num_cols].isna().copy()\n","\n","# Indeks multi\n","df_idx = df.set_index(['Provinsi', 'Tahun'])\n","provinsi_list = df['Provinsi'].dropna().unique()\n","\n","# Prefill helper: mean global per kolom (seluruh provinsi)\n","global_means = df[num_cols].mean(numeric_only=True)\n","\n","for prov in tqdm(provinsi_list, desc=\"Prefill global + Imputasi GAIN per provinsi\"):\n","    block = df_idx.loc[prov, num_cols]\n","    if isinstance(block, pd.Series):\n","        block = block.to_frame().T\n","\n","    # Kolom yang 100% NaN di provinsi ini\n","    all_nan_cols = block.columns[block.isna().all(axis=0)]\n","\n","    if len(all_nan_cols) > 0:\n","        # Rata-rata per tahun dari semua provinsi lain (global, exclude prov sendiri)\n","        peryear_means_excl = df[df['Provinsi'] != prov].groupby('Tahun')[all_nan_cols].mean()\n","        fy = peryear_means_excl.reindex(block.index)  # index = Tahun\n","        block.loc[:, all_nan_cols] = block.loc[:, all_nan_cols].fillna(fy)\n","        # Fallback terakhir ke mean global kolom jika masih NaN\n","        for c in all_nan_cols:\n","            if block[c].isna().any():\n","                block[c] = block[c].fillna(global_means[c])\n","        # Tulis balik ke df_idx sebelum GAIN\n","        df_idx.loc[prov, all_nan_cols] = block[all_nan_cols].values\n","\n","    # Jalankan GAIN\n","    arr = df_idx.loc[prov, num_cols].values.astype(np.float64)\n","    if np.isnan(arr).any():\n","        params = {'batch_size': 128, 'hint_rate': 0.7, 'alpha': 500, 'iterations': 15000, 'patience': 500}\n","        df_idx.loc[prov, num_cols] = gain_imputation(arr, params)\n","\n","df_final = df_idx.reset_index()\n","durasi = time.time() - start\n","print(f\"Durasi imputasi: {durasi:.2f} detik\")\n","\n","# ====== Simpan hasil dengan nilai imputasi bold + biru ======\n","def highlight_imputed(data, mask):\n","    style = pd.DataFrame('', index=data.index, columns=data.columns)\n","    for col in mask.columns:\n","        if col in data.columns:\n","            style[col] = mask[col].apply(lambda x: 'font-weight: bold; color: blue' if x else '')\n","    return style\n","\n","df_final.style.apply(lambda x: highlight_imputed(x, mask_missing), axis=None)\\\n","    .to_excel(OUT_XLSX, index=False, engine='openpyxl')\n","\n","# ====== Simpan waktu ======\n","pd.DataFrame([{'Tahap': 'Imputasi Final GAIN (prefill global per tahun)',\n","               'Durasi (detik)': durasi,\n","               'Durasi (menit)': durasi/60}])\\\n","  .to_excel(OUT_WAKTU, index=False)\n","\n","print(\"File hasil imputasi:\", OUT_XLSX)\n","print(\"File waktu eksekusi:\", OUT_WAKTU)\n","files.download(OUT_XLSX)\n","files.download(OUT_WAKTU)"]},{"cell_type":"markdown","source":["## Versi TRAINING GAIN per provinsi"],"metadata":{"id":"U3ZY6MHOm6f7"}},{"cell_type":"code","source":["# ==========================================\n","# TRAINING GAIN PER PROVINSI - PERMINTAAN (Versi Colab)\n","# ==========================================\n","\n","!pip -q install openpyxl xlsxwriter\n","\n","import pandas as pd\n","import numpy as np\n","import tensorflow as tf\n","from sklearn.preprocessing import MinMaxScaler\n","import joblib\n","import os\n","import time\n","from tqdm import tqdm\n","from google.colab import drive, files\n","import warnings\n","import random\n","import json\n","\n","warnings.filterwarnings(\"ignore\")\n","\n","# ==========================================\n","# MOUNT DRIVE DAN PATH\n","# ==========================================\n","drive.mount(\"/content/drive\")\n","\n","FILE_PATH = \"/content/drive/MyDrive/HASIL DATASET PERMINTAAN 26 KANWIL BULOG (BAPANAS)/DATASET PERMINTAAN 26 KANWIL.xlsx\"\n","OUTPUT_DIR = \"/content/drive/MyDrive/HASIL DATASET PERMINTAAN 26 KANWIL BULOG (BAPANAS)/Hasil Imputasi\"\n","os.makedirs(OUTPUT_DIR, exist_ok=True)\n","\n","# Nama hasil dibedakan dari versi awal\n","OUT_XLSX = os.path.join(OUTPUT_DIR, \"Imputasi GAIN 3.1_per_provinsi.xlsx\")\n","OUT_WAKTU = os.path.join(OUTPUT_DIR, \"LAPORAN_WAKTU_IMPUTASI_GAIN 3.1_per_provinsi.xlsx\")\n","\n","MODELS_DIR = os.path.join(OUTPUT_DIR, \"models_gain_permintaan\")\n","os.makedirs(MODELS_DIR, exist_ok=True)\n","\n","# ==========================================\n","# RANDOM SEED (stabil)\n","# ==========================================\n","SEED = 42\n","os.environ[\"PYTHONHASHSEED\"] = str(SEED)\n","np.random.seed(SEED)\n","tf.random.set_seed(SEED)\n","random.seed(SEED)\n","\n","# ==========================================\n","# PARAMETER GAIN (sama dengan code awal)\n","# ==========================================\n","GAIN_PARAMS = {\n","    \"batch_size\": 128,\n","    \"hint_rate\": 0.7,\n","    \"alpha\": 500,\n","    \"iterations\": 15000,\n","    \"patience\": 500,\n","}\n","\n","# ==========================================\n","# FUNGSI TRAIN GAIN PER PROVINSI\n","# ==========================================\n","def train_gain_for_province(data_x, gain_parameters, save_dir, feature_names):\n","    no, dim = data_x.shape\n","    if dim == 0:\n","        return data_x\n","\n","    os.makedirs(save_dir, exist_ok=True)\n","\n","    # Mask missing\n","    M = 1 - np.isnan(data_x).astype(float)\n","\n","    # Pra-isi mean kolom (setelah prefill global di luar fungsi)\n","    X_filled = data_x.copy()\n","    col_means = np.nanmean(X_filled, axis=0)\n","    col_means = np.where(np.isnan(col_means), 0.0, col_means)\n","    for j in range(dim):\n","        X_filled[:, j] = np.where(\n","            np.isnan(X_filled[:, j]),\n","            col_means[j],\n","            X_filled[:, j],\n","        )\n","\n","    # Normalisasi\n","    scaler = MinMaxScaler((0, 1))\n","    norm_data_x = scaler.fit_transform(X_filled)\n","    norm_data_x = np.where(np.isnan(data_x), 0.0, norm_data_x)\n","\n","    batch = gain_parameters.get(\"batch_size\", 128)\n","    hint = gain_parameters.get(\"hint_rate\", 0.7)\n","    alpha = gain_parameters.get(\"alpha\", 500)\n","    iters = gain_parameters.get(\"iterations\", 15000)\n","    patience = gain_parameters.get(\"patience\", 500)\n","\n","    tf.keras.backend.clear_session()\n","\n","    # Generator\n","    G = tf.keras.Sequential([\n","        tf.keras.layers.InputLayer((dim * 2,)),\n","        tf.keras.layers.Dense(dim * 2, activation=\"relu\"),\n","        tf.keras.layers.Dense(dim * 2, activation=\"relu\"),\n","        tf.keras.layers.Dense(dim, activation=\"relu\"),\n","        tf.keras.layers.Dense(dim, activation=\"relu\"),\n","        tf.keras.layers.Dense(dim, activation=\"sigmoid\"),\n","    ])\n","\n","    # Discriminator\n","    D = tf.keras.Sequential([\n","        tf.keras.layers.InputLayer((dim * 2,)),\n","        tf.keras.layers.Dense(dim, activation=\"relu\"),\n","        tf.keras.layers.Dense(dim, activation=\"relu\"),\n","        tf.keras.layers.Dense(dim, activation=\"sigmoid\"),\n","    ])\n","\n","    loss = tf.keras.losses.BinaryCrossentropy()\n","\n","    def g_loss(d_prob, m, g_samp, x):\n","        adv = -tf.reduce_mean((1 - m) * tf.math.log(d_prob + 1e-8))\n","        rec = tf.reduce_mean(tf.square((m * x) - (m * g_samp)))\n","        return adv + alpha * rec\n","\n","    g_opt = tf.keras.optimizers.Adam()\n","    d_opt = tf.keras.optimizers.Adam()\n","\n","    best, wait = float(\"inf\"), 0\n","\n","    # Training loop + early stopping\n","    for _ in range(iters):\n","        idx = np.random.permutation(no)[:batch]\n","        X_mb, M_mb = norm_data_x[idx, :], M[idx, :].astype(np.float32)\n","\n","        Z_mb = np.random.uniform(0, 0.1, [len(idx), dim]).astype(np.float32)\n","        B_mb = np.random.binomial(1, hint, M_mb.shape).astype(np.float32)\n","        H_mb = M_mb * B_mb + 0.5 * (1 - B_mb)\n","\n","        X_in = (X_mb * M_mb) + (1 - M_mb) * Z_mb\n","        G_in = tf.concat([tf.cast(X_in, tf.float32), M_mb], axis=1)\n","\n","        with tf.GradientTape() as g_t, tf.GradientTape() as d_t:\n","            G_samp = G(G_in)\n","            X_hat = (tf.cast(X_mb, tf.float32) * M_mb) + (G_samp * (1 - M_mb))\n","\n","            D_in = tf.concat(\n","                [X_hat, tf.cast(H_mb, tf.float32)],\n","                axis=1,\n","            )\n","            D_pr = D(D_in)\n","\n","            d_l = loss(M_mb, D_pr)\n","            g_l = g_loss(D_pr, M_mb, G_samp, tf.cast(X_mb, tf.float32))\n","\n","        d_opt.apply_gradients(zip(d_t.gradient(d_l, D.trainable_variables), D.trainable_variables))\n","        g_opt.apply_gradients(zip(g_t.gradient(g_l, G.trainable_variables), G.trainable_variables))\n","\n","        if g_l < best:\n","            best, wait = g_l, 0\n","        else:\n","            wait += 1\n","\n","        if wait >= patience:\n","            break\n","\n","    # Imputasi full data, Z_full 0–0.01 (sama code awal)\n","    Z_full = np.random.uniform(0, 0.01, norm_data_x.shape).astype(np.float32)\n","    X_in_full = (norm_data_x * M) + (1 - M) * Z_full\n","    G_in_full = tf.concat(\n","        [tf.cast(X_in_full, tf.float32), tf.cast(M, tf.float32)],\n","        axis=1,\n","    )\n","\n","    imputed_norm = G(G_in_full).numpy()\n","    imputed_norm = (M * norm_data_x) + ((1 - M) * imputed_norm)\n","    imputed = scaler.inverse_transform(imputed_norm)\n","\n","    final = (M * np.where(np.isnan(data_x), 0.0, data_x)) + ((1 - M) * imputed)\n","\n","    # Simpan artefak model untuk inference\n","    joblib.dump(scaler, os.path.join(save_dir, \"scaler_gain.pkl\"))\n","    np.save(os.path.join(save_dir, \"col_means.npy\"), col_means)\n","\n","    with open(os.path.join(save_dir, \"feature_names.json\"), \"w\") as f:\n","        json.dump(list(feature_names), f)\n","\n","    G.save(os.path.join(save_dir, \"gain_generator.h5\"))\n","\n","    return final\n","\n","# ==========================================\n","# MAIN PIPELINE IMPUTASI + TRAINING PER PROVINSI\n","# ==========================================\n","start = time.time()\n","\n","df = pd.read_excel(FILE_PATH)\n","\n","# Rapikan nama provinsi\n","df[\"Provinsi\"] = df[\"Provinsi\"].astype(str).str.strip()\n","\n","# Semua kolom numerik kecuali Tahun\n","num_cols = df.select_dtypes(include=np.number).columns.drop(\"Tahun\", errors=\"ignore\").tolist()\n","\n","# Mask awal untuk styling\n","mask_missing = df[num_cols].isna().copy()\n","\n","# Multi-index\n","df_idx = df.set_index([\"Provinsi\", \"Tahun\"])\n","provinsi_list = df[\"Provinsi\"].dropna().unique()\n","\n","# Prefill helper: mean global per kolom\n","global_means = df[num_cols].mean(numeric_only=True)\n","\n","for prov in tqdm(provinsi_list, desc=\"Prefill global + Training GAIN per provinsi\"):\n","    block = df_idx.loc[prov, num_cols]\n","    if isinstance(block, pd.Series):\n","        block = block.to_frame().T\n","\n","    # Kolom yang 100% NaN di provinsi ini\n","    all_nan_cols = block.columns[block.isna().all(axis=0)]\n","\n","    if len(all_nan_cols) > 0:\n","        # Rata-rata per tahun dari semua provinsi lain\n","        peryear_means_excl = (\n","            df[df[\"Provinsi\"] != prov]\n","            .groupby(\"Tahun\")[all_nan_cols]\n","            .mean()\n","        )\n","        fy = peryear_means_excl.reindex(block.index)\n","\n","        block.loc[:, all_nan_cols] = block.loc[:, all_nan_cols].fillna(fy)\n","\n","        # Fallback ke mean global jika masih NaN\n","        for c in all_nan_cols:\n","            if block[c].isna().any():\n","                block[c] = block[c].fillna(global_means[c])\n","\n","        df_idx.loc[prov, all_nan_cols] = block[all_nan_cols].values\n","\n","    # Jalankan GAIN + simpan model per provinsi\n","    arr = df_idx.loc[prov, num_cols].values.astype(np.float64)\n","    if np.isnan(arr).any():\n","        save_dir = os.path.join(MODELS_DIR, str(prov))\n","        imputed = train_gain_for_province(arr, GAIN_PARAMS, save_dir, num_cols)\n","        df_idx.loc[prov, num_cols] = imputed\n","\n","df_final = df_idx.reset_index()\n","durasi = time.time() - start\n","print(f\"Durasi imputasi: {durasi:.2f} detik\")\n","\n","# ==========================================\n","# SIMPAN HASIL IMPUTASI (BOLD + BIRU)\n","# ==========================================\n","def highlight_imputed(data, mask):\n","    style = pd.DataFrame(\"\", index=data.index, columns=data.columns)\n","    for col in mask.columns:\n","        if col in data.columns:\n","            style[col] = mask[col].apply(\n","                lambda x: \"font-weight: bold; color: blue\" if x else \"\"\n","            )\n","    return style\n","\n","df_final.style.apply(lambda x: highlight_imputed(x, mask_missing), axis=None) \\\n","    .to_excel(OUT_XLSX, index=False, engine=\"openpyxl\")\n","\n","# Simpan waktu eksekusi\n","pd.DataFrame([{\n","    \"Tahap\": \"Imputasi Final GAIN (prefill global per tahun, per provinsi)\",\n","    \"Durasi (detik)\": durasi,\n","    \"Durasi (menit)\": durasi / 60,\n","}]).to_excel(OUT_WAKTU, index=False)\n","\n","print(\"File hasil imputasi:\", OUT_XLSX)\n","print(\"File waktu eksekusi:\", OUT_WAKTU)\n","\n","# Opsional download\n","files.download(OUT_XLSX)\n","files.download(OUT_WAKTU)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":592},"id":"L2Gd2U